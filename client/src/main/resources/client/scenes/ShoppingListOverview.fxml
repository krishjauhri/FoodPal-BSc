<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane
        xmlns="http://javafx.com/javafx/25"
        xmlns:fx="http://javafx.com/fxml/1"
        fx:controller="client.scenes.ShoppingListOverviewCtrl">

    <top>
        <VBox spacing="8">
            <padding>
                <Insets top="12" right="12" bottom="12" left="12"/>
            </padding>

            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="To Be Added" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="Add to shopping list" onAction="#addToShoppingList"/>
                <Button text="Back" onAction="#backToRecipes"/>
            </HBox>

            <Separator/>
        </VBox>
    </top>

    <center>
        <VBox spacing="10">
            <padding>
                <Insets top="12" right="12" bottom="12" left="12"/>
            </padding>

            <TableView fx:id="table" editable="true" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="nameCol" text="Ingredient" prefWidth="250"/>
                    <TableColumn fx:id="amountCol" text="Amount" prefWidth="120"/>
                    <TableColumn fx:id="unitCol" text="Unit" prefWidth="120"/>
                </columns>
            </TableView>
        </VBox>
    </center>

</BorderPane>