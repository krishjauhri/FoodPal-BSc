<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ButtonBar?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Text?>

<BorderPane xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="client.scenes.ShoppingListOverviewCtrl">

    <top>
        <VBox spacing="8">
            <padding>
                <Insets bottom="12" left="12" right="12" top="12" />
            </padding>

            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label style="-fx-font-size: 18px; -fx-font-weight: bold;" text="To Be Added" />
                <Region HBox.hgrow="ALWAYS" />
                <Button onAction="#addToShoppingList" text="Add to shopping list" />
                <Button onAction="#backToRecipes" text="Back" />
            </HBox>

            <Separator />
        </VBox>
    </top>

    <center>
        <VBox spacing="10">
            <padding>
                <Insets bottom="12" left="12" right="12" top="12" />
            </padding>
            <ButtonBar prefHeight="40.0" prefWidth="200.0">
            <buttons>
               <Text strokeType="OUTSIDE" strokeWidth="0.0" text="Ingredient:" />
               <ComboBox fx:id="ingredientBox" prefWidth="250.0"
                         promptText="Select Ingredient"
                         HBox.hgrow="ALWAYS" />
               <Button onAction="#addRow" mnemonicParsing="false" text="Add" />
               <Button onAction="#deleteRow" mnemonicParsing="false" text="Delete" />
            </buttons>
            </ButtonBar>

            <TableView fx:id="table" editable="true" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="nameCol" prefWidth="250" text="Ingredient" />
                    <TableColumn fx:id="amountCol" prefWidth="120" text="Amount" />
                    <TableColumn fx:id="unitCol" prefWidth="120" text="Unit" />
                </columns>
            </TableView>
        </VBox>
    </center>

</BorderPane>
