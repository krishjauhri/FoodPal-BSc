<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Text?>

<BorderPane xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="client.scenes.ShoppingListCtrl">

    <top>
        <VBox spacing="8">
            <padding>
                <Insets bottom="12" left="12" right="12" top="12" />
            </padding>

            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label style="-fx-font-size: 18px; -fx-font-weight: bold;" text="Shopping List" />
                <Region HBox.hgrow="ALWAYS" />

                <Button onAction="#resetList" text="Reset" />
                <Button onAction="#downloadList" text="Download" />
            </HBox>

            <Separator />
        </VBox>
    </top>

    <center>
        <VBox spacing="10">
            <padding>
                <Insets bottom="12" left="12" right="12" top="12" />
            </padding>

            <HBox alignment="CENTER_LEFT" spacing="10">
            <Text strokeType="OUTSIDE" strokeWidth="0.0" text="Ingredient:" />
                <ComboBox fx:id="ingredientBox" prefWidth="250.0"
                          promptText="Select an ingredient"
                          HBox.hgrow="ALWAYS" />
                <Button onAction="#createNewIngredientMain" text="New Ingredient" />
                <Button onAction="#addItem" text="Add" />
            </HBox>

            <ListView fx:id="shoppingListView" VBox.vgrow="ALWAYS" />

            <HBox alignment="CENTER_LEFT" spacing="10">
                <Button onAction="#removeSelected" text="Remove selected" />
            </HBox>
        </VBox>
    </center>

</BorderPane>
