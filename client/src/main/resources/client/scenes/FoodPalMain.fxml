<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="400.0" prefWidth="600.0" styleClass="root" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="client.scenes.FoodPalMainCtrl">

    <top>
        <HBox alignment="CENTER" spacing="14" styleClass="topbar" BorderPane.alignment="CENTER">
            <children>
                <Label styleClass="title" text="FoodPal" />

                <Button onAction="#refreshRecipes" styleClass="btn-secondary" text="Refresh" />
                <Button fx:id="addRecipeButton" mnemonicParsing="false" onAction="#addRecipe" styleClass="btn-primary" text="Add Recipe" />
                <Button onAction="#showIngredientsList" text="Ingredients" />
                <Button onAction="#showShoppingList" text="Shopping List" />
                <Button onAction="#backRecipes" text="Recipes" />

            </children>
        </HBox>
    </top>

    <center>
        <BorderPane fx:id="contentPane">
            <center>
        <SplitPane dividerPositions="0.38" styleClass="main-split">
            <items>

                <VBox styleClass="pane">
                    <children>
                        <TextField fx:id="searchField" promptText="Search recipes (name, ingredients, steps)..." />
                        <ListView fx:id="colRecipeList" styleClass="recipe-list" VBox.vgrow="ALWAYS" />
                    </children>
                </VBox>

                <VBox fx:id="detailPane" spacing="12" styleClass="pane">
                    <padding>
                        <Insets bottom="16" left="16" right="16" top="16" />
                    </padding>

                    <children>

                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <Label fx:id="recipeTitle" styleClass="section-title" text="Select one recipe" />
                            <HBox HBox.hgrow="ALWAYS" />
                            <Button onAction="#editRecipeName" styleClass="btn-secondary" text="Edit name" />
                            <Button onAction="#deleteSelectedRecipe" styleClass="btn-danger" text="Delete" />
                            <Button onAction="#downloadRecipe" styleClass="btn-secondary" text="Download" />
                            <Button mnemonicParsing="false" onAction="#cloneRecipe" styleClass="btn-secondary" text="Clone" />
                        </HBox>

                        <Separator maxWidth="Infinity" />

                        <VBox spacing="10" styleClass="card" VBox.vgrow="ALWAYS">
                            <children>
                                <HBox alignment="CENTER_LEFT" spacing="8">
                                    <Label styleClass="card-title" text="Ingredients" />
                                    <HBox HBox.hgrow="ALWAYS" />
                                    <Button mnemonicParsing="false" onAction="#addIngredient" styleClass="btn-primary" text="+ Add" />
                                    <Button mnemonicParsing="false" onAction="#editSelectedIngredient" styleClass="btn-secondary" text="Edit" />
                                    <Button mnemonicParsing="false" onAction="#deleteSelectedIngredient" styleClass="btn-danger" text="Delete" />
                                </HBox>

                                <ListView fx:id="ingredientsList" VBox.vgrow="ALWAYS" />

                                <VBox fx:id="ingredientsBox" spacing="5" />
                            </children>
                        </VBox>

                        <VBox spacing="10" styleClass="card" VBox.vgrow="ALWAYS">
                            <children>
                                <HBox alignment="CENTER_LEFT" spacing="10">
                                    <Label styleClass="card-title" text="Preparation" />
                                    <HBox HBox.hgrow="ALWAYS" />
                                    <Button mnemonicParsing="false" onAction="#addStep" styleClass="btn-primary" text="+ Add step" />
                                </HBox>

                                <ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="scroll-clean" VBox.vgrow="ALWAYS">
                                    <content>
                                        <VBox fx:id="stepsBox" spacing="8.0" />
                                    </content>
                                </ScrollPane>
                            </children>
                        </VBox>

                    </children>
                </VBox>

            </items>
        </SplitPane>
            </center>
        </BorderPane>
    </center>
</BorderPane>
